{
  "name": "@poutine/hub",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "fastify": "^5.3.3",
    "@fastify/cors": "^11.0.0",
    "@fastify/cookie": "^11.0.0",
    "better-sqlite3": "^11.9.1",
    "argon2": "^0.43.0",
    "jose": "^6.0.11",
    "pino": "^9.6.0",
    "undici": "^7.5.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.13.0",
    "typescript": "^5.8.0",
    "tsx": "^4.19.0",
    "vitest": "^3.1.0",
    "eslint": "^9.21.0",
    "@eslint/js": "^9.21.0",
    "typescript-eslint": "^8.30.0"
  }
}
